# Copy this file to .env and fill in real values. Never commit .env.

APP_NAME="SAUL SEO Tool"
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Ho_Chi_Minh

# Random 32+ char secret used to encrypt stored API tokens / secrets (openssl_encrypt).
# Generate one with: php -r "echo bin2hex(random_bytes(16));"
APP_KEY=change_this_to_a_random_32_char_secret

# Single admin account. Generate the hash with:
# php -r "echo password_hash('your-password', PASSWORD_DEFAULT);"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Path to the SQLite database file (relative to project root).
DB_PATH=storage/db.sqlite

# Directory holding the SSH private key(s) used to connect to your VPS servers.
SSH_KEY_DIR=storage/keys
